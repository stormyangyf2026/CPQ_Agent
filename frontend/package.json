{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "clean": "find src -name '*.js' -not -path '*/node_modules/*' -delete",
    "predev": "npm run clean",
    "dev": "vite",
    "prebuild": "npm run clean",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:all": "vite build && electron-builder --mac --win"
  },
  "build": {
    "appId": "com.cpq.agent",
    "productName": "CPQ Agent",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc",
          "!*.spec",
          "!build/**",
          "!dist/**",
          "!Dockerfile"
        ]
      },
      {
        "from": "../config",
        "to": "config",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "public/icon-512.png",
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon-512.png"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  },
  "dependencies": {
    "element-plus": "^2.14.2",
    "highlight.js": "^11.11.1",
    "js-yaml": "^5.2.1",
    "markdown-it": "^14.3.0",
    "pinia": "^2.3.1",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.7.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "resedit": "^3.0.2",
    "typescript": "~5.5.0",
    "vite": "^5.4.21",
    "vue-tsc": "^2.0.0"
  }
}
